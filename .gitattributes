# Normalize line endings to LF on commit, keep LF on checkout
* text=auto eol=lf
 
# Force LF for all code files
*.gml        text eol=lf
*.yy         text eol=lf
*.yyp        text eol=lf
*.json       text eol=lf
*.js         text eol=lf
*.ts         text eol=lf
*.html       text eol=lf
*.css        text eol=lf
*.md         text eol=lf
*.txt        text eol=lf
*.sh         text eol=lf
*.xml        text eol=lf
 
# Binary files — never touch line endings
*.png        binary
*.jpg        binary
*.jpeg       binary
*.gif        binary
*.bmp        binary
*.ico        binary
*.wav        binary
*.ogg        binary
*.mp3        binary
*.mp4        binary
*.ttf        binary
*.woff       binary
*.woff2      binary
